# Configuração do Banco de Dados PostgreSQL
# Substitua os valores abaixo com suas configurações do DBeaver

DB_HOST=localhost
DB_PORT=5432
DB_NAME=seu_banco
DB_USER=seu_usuario  
DB_PASSWORD=sua_senha

# Ou use a URL de conexão completa
# DATABASE_URL=postgresql://usuario:senha@host:porta/banco

# Nome da tabela onde os dados serão salvos
TABLE_NAME=newtable
